{
  "name": "ai-interview-v2-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "electron": "node scripts/run-electron.mjs dist-electron/electron/main/main.js",
    "electron:dev": "npm run build:electron && node scripts/run-electron.mjs dist-electron/electron/main/main.js",
    "electron:prod": "npm run build && node scripts/run-electron.mjs dist-electron/electron/main/main.js"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^37.2.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
